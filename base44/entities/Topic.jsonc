{
  "title": "Topic",
  "type": "object",
  "name": "Topic",
  "properties": {
    "name": {
      "type": "string",
      "description": "Topic name (e.g. Positive Thinking, Self-Love, Hustle, Self-Esteem, Social Anxiety, Healing, Strength, Short Quotes)"
    },
    "icon": {
      "type": "string",
      "description": "Icon identifier for the topic"
    },
    "description": {
      "type": "string",
      "description": "Short description of the topic"
    },
    "order": {
      "type": "number",
      "default": 0,
      "description": "Display order for sorting"
    },
    "is_premium": {
      "type": "boolean",
      "default": false,
      "description": "Whether this topic is premium-only"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Shelves this topic belongs to (e.g. Daily Mindset, Inner Work, Hustle & Wins, Founders & Business). A topic can appear under multiple sections."
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "read": {},
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}